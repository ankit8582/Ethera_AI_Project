# Backend Environment Variables
PORT=5000
NODE_ENV=development

# MongoDB Connection - Use MongoDB Atlas or Railway MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/team-task-manager?retryWrites=true&w=majority

# Database Mode - set to 'true' to use JSON database instead of MongoDB
USE_JSON_DB=false

# CORS Settings - Frontend URL
CORS_ORIGIN=http://localhost:5173

# For production, use:
# CORS_ORIGIN=https://team-task-manager.up.railway.app
